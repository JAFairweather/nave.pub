# Caddy for the relay box — auto-TLS, WSS to strfry. Caddy upgrades WebSocket
# connections transparently, so no special config beyond the reverse_proxy.
# No global email block: Let's Encrypt email is optional, and requiring an env
# var here just crash-loops Caddy when it's unset. Add `tls you@example.com`
# inside the site block if you want expiry notices.
relay.nave.pub {
	reverse_proxy strfry:7777
}

# The bunker (Bunker46 NIP-46 signer) runs in its own compose. Caddy reaches its
# web container DIRECTLY over the shared `naveedge` docker network (container-to-
# container) instead of through the host's published :8080 — routing through the
# host port ran into the box's docker/nftables firewall and flapped (intermittent
# 502 / plain-text error bodies the browser tried to download as document.txt).
# The bunker web container is attached to `naveedge` by deploy/relay/fix-bunker-proxy.sh.
bunker.nave.pub {
	reverse_proxy bunker46-web-1:8080
}
