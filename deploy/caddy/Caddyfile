# The one front door for everything on nave.pub.
# Caddy fetches + renews Let's Encrypt certs automatically, as long as
# each name's DNS A record points at this box and ports 80+443 are open.

{
	email {$ACME_EMAIL}
}

# The hub — the ecosystem front door. The nave.pub repo, synced by sites.sh
# into sites/nave and served from /srv/apps/nave (the same read-only mount as
# every app), so assets/ and .well-known/ are served too. The apex gets its
# OWN cert block: bundling www in here would make Caddy order ONE cert for
# both names, and if www fails to validate (only the wildcard, no explicit A
# record) the whole order fails and the apex goes down with it. Keep separate.
nave.pub {
	root * /srv/apps/nave
	encode gzip zstd
	# NIP-05: clients resolve luke@nave.pub / nave@nave.pub by fetching
	# /.well-known/nostr.json cross-origin, so it needs permissive CORS
	# and a JSON content-type.
	@nip05 path /.well-known/nostr.json
	header @nip05 Access-Control-Allow-Origin "*"
	header @nip05 Content-Type "application/json"
	file_server
}

# www just points at the apex. Its own block, so if its cert ever stalls
# it can't take nave.pub with it.
www.nave.pub {
	redir https://nave.pub{uri} permanent
}

# The Noir game client — the noir repo, synced to /srv/apps/noir. Served
# from the repo root so the client's sibling imports (../lib, ../gm, …)
# resolve; `/` lands on /client/. The Director is a separate subdomain.
noir.nave.pub {
	root * /srv/apps/noir
	encode gzip zstd
	# .mjs must be served as JavaScript or the browser refuses the module.
	@mjs path *.mjs
	header @mjs Content-Type "text/javascript; charset=utf-8"
	redir / /client/ 302
	file_server
}

# The Noir Director API — the AI game master. The client above calls this.
director.nave.pub {
	reverse_proxy director:8787
}

# --- The apps, each served off the box at its own subdomain -----------
# sites.sh syncs each app's repo into deploy/sites/<name>, mounted read-only
# at /srv/apps/<name>. We serve each REPO ROOT (not a subdir) so the apps'
# sibling imports (../lib, ../shared, ../vendor) resolve. Caddy issues a
# Let's Encrypt cert per subdomain automatically. Adding the next app is one
# line here + one line in sites.sh.
(app) {
	root * /srv/apps/{args[0]}
	encode gzip zstd
	@mjs path *.mjs
	header @mjs Content-Type "text/javascript; charset=utf-8"
	file_server
}

nvelope.nave.pub {
	import app nvelope
}
nontact.nave.pub {
	import app nontact
}
notegate.nave.pub {
	import app notegate
}
ntrigue.nave.pub {
	import app ntrigue
}
nvoy.nave.pub {
	import app nvoy
}
nherit.nave.pub {
	import app nherit
}
nscope.nave.pub {
	import app nscope
}
nact.nave.pub {
	# /api/proxy/* is Nactor's INTERNAL credential-injecting egress proxy. It must
	# NEVER be reachable from the internet — the only public path to Nactor is
	# through this vhost, so we refuse it here. Internal callers (OpenClaw et al.)
	# reach it directly over the nave network at http://nactor:8791/api/proxy/…,
	# never through Caddy. handle blocks are mutually exclusive + source-ordered,
	# so this match wins over the /api/* handler below. (Defense in depth: Nactor
	# also token-gates the route and is never published.)
	handle /api/proxy/* {
		respond "not found" 404
	}
	# /api/* → Nactor (the NIP-98-gated Nact runtime).
	handle /api/* {
		reverse_proxy nactor:8791
	}
	# Everything else → the static app.
	handle {
		root * /srv/apps/nact
		encode gzip zstd
		@mjs path *.mjs
		header @mjs Content-Type "text/javascript; charset=utf-8"
		file_server
	}
}

# --- Luke — a delegated agent, cockpit behind a nostr-signed gate ------
# See the luke repo's LUKE.md. Two planes on one host:
#   /            → Luke's public card + gate endpoints (luke-service)
#   /cockpit*    → the real OpenClaw Control UI (host :57419), but ONLY
#                  after forward_auth to the gate returns 200. The gate
#                  opens for exactly one key: your NIP-98-signed master npub.
# Auth model (OpenClaw "trusted-proxy" mode — no gateway token): after the gate
# passes, we assert the authenticated user to OpenClaw via X-Forwarded-User;
# OpenClaw trusts this proxy and authorizes without a token. Configure OpenClaw:
#   gateway.auth.mode = "trusted-proxy"
#   gateway.trustedProxies = [<this proxy's source IP/CIDR>]   # see ops probe
#   gateway.auth.trustedProxy.userHeader = "X-Forwarded-User"
#   gateway.auth.trustedProxy.allowUsers = ["jaf@dequalsf.com"]  # or [] = any
# A shared token cannot coexist with trusted-proxy mode, so OPENCLAW_GATEWAY_TOKEN
# is retired. header_up only applies to requests that already cleared the gate
# (and rides the WebSocket upgrade), so an unauthenticated caller never reaches it.
luke.nave.pub {
	encode gzip zstd

	# The cockpit: OpenClaw, gated by the nostr-signed session.
	@cockpit path /cockpit /cockpit/*
	handle @cockpit {
		forward_auth luke:8790 {
			uri /gate/verify
		}
		reverse_proxy host.docker.internal:57419 {
			header_up X-Forwarded-User jaf@dequalsf.com
		}
	}

	# Everything else: Luke's public card + the /gate/* login flow.
	handle {
		reverse_proxy luke:8790
	}
}
