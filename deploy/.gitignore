# Box-only, never committed:
.env            # Director secrets (ANTHROPIC_API_KEY, director nsec, ACME_EMAIL)
luke.env        # decrypted from the luke repo's secrets.enc.env at deploy time (nactor reads this — has the brokered creds)
luke-consumer.env # luke.env with brokered creds (ANTHROPIC/TELEGRAM) stripped — what the consumers read
nactor.env      # Nactor's own grantee key (NACTOR_NSEC), minted on the box by ops/gen-nactor-key.sh
brain.env       # brain identity (BRAIN_NSEC) + NACT_BROKER_URL, minted on the box by ops/gen-brain-key.sh
brain-state/    # box-local continuity ledger for luke-brain (proposed/approved/passed) — survives redeploys
openclaw.env    # the self-hosted openclaw service's env (ANTHROPIC_API_KEY, TZ) — box-local, no gateway token
openclaw-state/ # migrated OpenClaw state (agents/memory/config), refreshed from live by ops/oc-resync-boot.sh
openclaw-upgradetest/ # throwaway state copy for ops/oc-upgrade-test.sh (auto-removed; ignored in case a run is interrupted)
sites/          # fresh clones of every repo, synced by sites.sh
