# Box-only, never committed:
.env            # Director secrets (ANTHROPIC_API_KEY, director nsec, ACME_EMAIL)
nave.env        # the platform secret bundle, decrypted from secrets/nave.enc.env at deploy time (nactor reads this — has the brokered creds)
nave-consumer.env # nave.env with brokered creds stripped — what the consumers read
luke.env        # transition alias of nave.env (kept while consumers still reference it)
luke-consumer.env # transition alias of nave-consumer.env
nactor.env      # Nactor's own grantee key (NACTOR_NSEC), minted on the box by ops/gen-nactor-key.sh
brain.env       # brain identity (BRAIN_NSEC) + NACT_BROKER_URL, minted on the box by ops/gen-brain-key.sh
brain-state/    # box-local continuity ledger for luke-brain (proposed/approved/passed) — survives redeploys
luke-state/     # box-local pending-proposal store (pending.json) for luke-poster — survives redeploys
openclaw.env    # the self-hosted openclaw service's env (ANTHROPIC_API_KEY, TZ) — box-local, no gateway token
openclaw-state/ # migrated OpenClaw state (agents/memory/config), refreshed from live by ops/oc-resync-boot.sh
openclaw-upgradetest/ # throwaway state copy for ops/oc-upgrade-test.sh (auto-removed; ignored in case a run is interrupted)
luke-brain-deploy.key # box-local SSH deploy key for the private luke-brain backup repo (minted by ops/brain-backup-setup.sh)
luke-brain-deploy.key.pub # its public half (printed by setup to add as the repo's write deploy key)
luke-brain-repo/ # box-local clone of the private luke-brain repo (encrypted brain snapshots pushed from here)
sites/          # fresh clones of every repo, synced by sites.sh
luke-mail.env   # Gmail app password for himalaya (box-local; ops/mail-setup.sh reads it)
openclaw-tools/ # pinned static binaries mounted into the openclaw container (himalaya etc.)
nvoy-mcp.env    # generated by sites.sh: NVOY_NSEC (← NACTOR_NSEC) + NVOY_RELAYS — the nvoy-mcp service's key custody (M7)
.m7-mcp-transport # box-local M7 cutover marker (ops/m7-cutover.sh); while present, sites.sh keeps NACTOR_NSEC out of nactor's envs

# The nave-owned SOPS bundle: the ENCRYPTED file is committed (only the box can
# decrypt it); any PLAINTEXT temp created for a re-encrypt must never be.
secrets/*.env
!secrets/*.enc.env
